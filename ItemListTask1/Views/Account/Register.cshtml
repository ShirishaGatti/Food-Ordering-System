@using ItemListModel.ViewModel
@model RegisterViewModel
@{
    ViewData["Title"] = "Register Page";
}
<!-- Bootstrap -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
<!-- Bootstrap Icons -->
<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<!-- Your style.css -->
<link href="~/Content/css/register.css" rel="stylesheet" />
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="login-card p-5">

                @using (Html.BeginForm("Register", "Account", FormMethod.Post, new { id = "registerForm" }))
                {
                    @Html.AntiForgeryToken()

                    <div class="row g-4">
                        <!-- ROLE -->
                        <div class="col-12 mb-4">
                            <label class="form-label fw-bold text-dark mb-3">
                                Select Role
                            </label>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    @Html.RadioButtonFor(
                                        m => m.Role,
                                        "User",
                                        new
                                        {
                                            @class = "btn-check",
                                            id = "userRole"
                                        })
                                    <label class="role-card"
                                           for="userRole">
                                        <i class="bi bi-person-fill role-icon"></i>
                                        <span>User</span>
                                    </label>
                                </div>
                                <div class="col-md-6">
                                    @Html.RadioButtonFor(
                                        m => m.Role,
                                        "Restaurant",
                                        new
                                        {
                                            @class = "btn-check",
                                            id = "restaurantRole"
                                        })
                                    <label class="role-card"
                                           for="restaurantRole">
                                        <i class="bi bi-shop role-icon"></i>
                                        <span>Restaurant</span>
                                    </label>
                                </div>
                            </div>
                        </div>
                        <!-- NAME -->
                        <div class="col-md-6 mb-4">
                            @Html.LabelFor(
                                m => m.Name,
                                "Username",
                                new { @class = "form-label fw-semibold", id = "nameLabel" })
                            <div class="input-group">
                                <span class="input-group-text custom-input-icon">
                                    <i class="bi bi-person-fill"></i>
                                </span>
                                @Html.TextBoxFor(
                                    m => m.Name,
                                    new
                                    {
                                        @class = "form-control custom-input",
                                        placeholder = "Enter Name"
                                    })
                            </div>
                        </div>
                        <!-- EMAIL -->
                        <div class="col-md-6 mb-4">
                            @Html.LabelFor(m => m.Email, "Email", new { @class = "form-label fw-semibold" })
                            <div class="input-group">
                                <span class="input-group-text custom-input-icon">
                                    <i class="bi bi-envelope-fill"></i>
                                </span>
                                @Html.TextBoxFor(
                                    m => m.Email,
                                    new
                                    {
                                        type = "email",
                                        @class = "form-control custom-input",
                                        placeholder = "Enter Email"
                                    })
                            </div>
                        </div>
                        <!-- PASSWORD -->
                        <div class="col-md-6 mb-4">
                            @Html.LabelFor(m => m.Password, "Password", new { @class = "form-label fw-semibold" })
                            <div class="input-group">
                                <span class="input-group-text custom-input-icon">
                                    <i class="bi bi-lock-fill"></i>
                                </span>
                                @Html.PasswordFor(
                                    m => m.Password,
                                    new
                                    {
                                        @class = "form-control custom-input",
                                        placeholder = "Enter Password"
                                    })
                            </div>
                        </div>
                        <!-- DOB -->
                        <div class="col-md-6 mb-4" id="dobSection">
                            @Html.LabelFor(m => m.DateOfBirth, "Date Of Birth", new { @class = "form-label fw-semibold" })
                            <div class="input-group">
                                <span class="input-group-text custom-input-icon">
                                    <i class="bi bi-calendar-date-fill"></i>
                                </span>
                                @Html.TextBoxFor(
                                    m => m.DateOfBirth,
                                    "{0:yyyy-MM-dd}",
                                    new
                                    {
                                        type = "date",
                                        @class = "form-control custom-input"
                                    })
                            </div>
                        </div>
                        <!-- ADDRESS -->
                        <div class="col-md-6 mb-4">
                            @Html.LabelFor(m => m.Address, "Address", new { @class = "form-label fw-semibold" })
                            <div class="input-group">
                                <span class="input-group-text custom-input-icon">
                                    <i class="bi bi-geo-alt-fill"></i>
                                </span>
                                @Html.TextAreaFor(
                                    m => m.Address,
                                    new
                                    {
                                        rows = 2,
                                        @class = "form-control custom-input",
                                        placeholder = "Enter Address"
                                    })
                            </div>
                        </div>
                        <!-- CONTACT -->
                        <div class="col-md-6 mb-4">
                            @Html.LabelFor(m => m.Contact, "Contact", new { @class = "form-label fw-semibold" })
                            <div class="input-group">
                                <span class="input-group-text custom-input-icon">
                                    <i class="bi bi-telephone-fill"></i>
                                </span>
                                @Html.TextBoxFor(
                                    m => m.Contact,
                                    new
                                    {
                                        @class = "form-control custom-input",
                                        placeholder = "Enter Contact Number"
                                    })
                            </div>
                        </div>
                        <!-- BUTTON -->
                        <div class="d-grid mt-4">
                            <button type="submit"
                                    class="btn register-btn">
                                CREATE ACCOUNT

                            </button>
                        </div>
                        <!-- LOGIN -->
                        <div class="text-center mt-4">
                            Already have an account?
                            @Html.ActionLink("SIGN IN HERE", "Login", "Account", null, new { @class = "signup-link" })
                        </div>
                    </div>
                }
            </div>
        </div>
        </div>
    </div>
</div>
@section scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script>
        $(document).ready(function () {
            function toggleFields() {
                let role = $("input[name='Role']:checked").val();

                if (role === "Restaurant") {
                    $("#nameLabel").text("Restaurant Name");
                    $("#dobSection").hide();
                } else {
                    $("#nameLabel").text("Username");
                    $("#dobSection").show();
                }
            }
            toggleFields();
            $("input[name='Role']").change(function () {
                toggleFields();
            });
        });
    </script>
}
