<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>Login Page</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Your style.css -->
    <link href="~/Content/css/register.css" rel="stylesheet" />
</head>
<body>
<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-10">

            <div class="login-card row g-0">

                <!-- LEFT PANEL 
                <div class="col-md-5 left-panel d-flex align-items-center justify-content-center">

                    <div class="text-center company-box">

                        <div class="company-icon mb-4">
                            <i class="bi bi-shop"></i>
                        </div>

                        <h1 class="fw-bold text-white">
                            Foodies
                        </h1>

                        <p class="company-text mt-4">
                            Welcome back! Manage users, restaurants
                            and admin access with a modern dashboard
                            experience.
                        </p>

                    </div>

                </div>-->
                <div class="row">
                    <!-- ROLE -->
                    <div class="col-12 mb-4">
                        <label class="form-label fw-bold text-dark mb-3">
                            Select Role
                        </label>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <input type="radio"
                                       class="btn-check"
                                       name="role"
                                       id="userRole"
                                       value="User"
                                       checked>
                                <label class="role-card"
                                       for="userRole">
                                    <i class="bi bi-person-fill role-icon"></i>
                                    <span>User</span>
                                </label>
                            </div>
                            <div class="col-md-6">
                                <input type="radio"
                                       class="btn-check"
                                       name="role"
                                       id="restaurantRole"
                                       value="Restaurant">
                                <label class="role-card"
                                       for="restaurantRole">
                                    <i class="bi bi-shop role-icon"></i>
                                    <span>Restaurant</span>
                                </label>
                            </div>
                        </div>
                    </div>
                    <!-- NAME -->
                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-semibold"
                               id="nameLabel">
                            Username

                        </label>
                        <div class="input-group">
                            <span class="input-group-text custom-input-icon">
                                <i class="bi bi-person-fill"></i>
                            </span>
                            <input type="text"
                                   class="form-control custom-input"
                                   placeholder="Enter Name">
                        </div>
                    </div>
                    <!-- EMAIL -->
                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-semibold">
                            Email
                        </label>
                        <div class="input-group">
                            <span class="input-group-text custom-input-icon">
                                <i class="bi bi-envelope-fill"></i>
                            </span>
                            <input type="email"
                                   class="form-control custom-input"
                                   placeholder="Enter Email">
                        </div>
                    </div>
                    <!-- PASSWORD -->
                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-semibold">
                            Password
                        </label>
                        <div class="input-group">
                            <span class="input-group-text custom-input-icon">
                                <i class="bi bi-lock-fill"></i>
                            </span>
                            <input type="password"
                                   class="form-control custom-input"
                                   placeholder="Enter Password">
                        </div>
                    </div>
                    <!-- DOB -->
                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-semibold">
                            Date Of Birth
                        </label>
                        <div class="input-group">
                            <span class="input-group-text custom-input-icon">
                                <i class="bi bi-calendar-date-fill"></i>
                            </span>
                            <input type="date"
                                   class="form-control custom-input">
                        </div>
                    </div>
                    <!-- ADDRESS -->
                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-semibold">
                            Address
                        </label>
                        <div class="input-group">
                            <span class="input-group-text custom-input-icon">
                                <i class="bi bi-geo-alt-fill"></i>
                            </span>
                            <textarea class="form-control custom-input"
                                      rows="2"
                                      placeholder="Enter Address"></textarea>
                        </div>
                    </div>
                    <!-- CONTACT -->
                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-semibold">
                            Contact
                        </label>
                        <div class="input-group">
                            <span class="input-group-text custom-input-icon">
                                <i class="bi bi-telephone-fill"></i>
                            </span>
                            <input type="text"
                                   class="form-control custom-input"
                                   placeholder="Enter Contact Number">
                        </div>
                    </div>

                    <!-- BUTTON -->
                    <div class="d-grid mt-4">

                        <button type="submit"
                                class="btn register-btn">

                            CREATE ACCOUNT

                        </button>

                    </div>

                    <!-- LOGIN -->
                    <div class="text-center mt-4">

                        Already have an account?

                        <a href="/Account/Login"
                           class="signup-link">

                            SIGN IN HERE

                        </a>

                    </div>

                    </form>

                </div>

                </div>

            </div>

        </div>

    </div>

</div>
</body></html>

<script>

    $(document).ready(function () {

        $("input[name='role']").change(function () {

            let role = $(this).val();

            if (role === "Restaurant") {

                $("#nameLabel").text("Restaurant Name");
            }
            else {

                $("#nameLabel").text("Username");
            }

        });

    });

</script>
