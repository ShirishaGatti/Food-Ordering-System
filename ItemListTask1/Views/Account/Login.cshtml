@using ItemListModel.ViewModel
@model LoginViewModel
@{
    ViewData["Title"] = "Login Page";
}
<!-- Bootstrap -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
<!-- Bootstrap Icons -->
<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<!-- Your style.css -->
<link href="~/Content/login.css" rel="stylesheet" />
<div class="container login-wrapper">
    <div class="row g-0 login-card">
        <!-- LEFT SIDE -->
        <div class="col-md-5 left-panel d-flex align-items-center justify-content-center">
            <div class="text-center company-box">
                <div class="company-icon mb-4">
                    <i class="bi bi-shop"></i>
                </div>
                <h2 class="fw-bold">Foodies</h2>
                <p class="mt-3 px-4">
                    Welcome back! Manage users, restaurants and admin access
                    with a modern dashboard experience.
                </p>
            </div>
        </div>
        <!-- RIGHT SIDE -->
        <div class="col-md-7 bg-white">
            <div class="login-form-section">
                <h2 class="login-title mb-2">
                    Members Log In
                </h2>
                <p class="login-subtitle">
                    Enter your credentials to continue
                </p>
                @using (Html.BeginForm("Login", "Account", FormMethod.Post, new { id = "loginForm" }))
                {
                    @Html.AntiForgeryToken()

                    <!-- USERNAME -->
                    <div class="mb-4">
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-person-fill"></i>
                            </span>
                            @Html.TextBoxFor(
                                m => m.Email,
                                new
                                {
                                    @class = "form-control custom-input",
                                    placeholder = "Email"
                                })
                        </div>
                    </div>

                    <!-- PASSWORD -->
                    <div class="mb-4">
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-lock-fill"></i>
                            </span>
                            @Html.PasswordFor(
                                m => m.Password,
                                new
                                {
                                    @class = "form-control custom-input",
                                    placeholder = "Password"
                                })
                            <span class="input-group-text" id="togglePassword" style="cursor:pointer">
                                <i class="bi bi-eye-fill" id="eyeIcon"></i>
                            </span>
                        </div>
                    </div>

                    <!-- ROLE -->
                    <div class="mb-4">
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-person-badge-fill"></i>
                            </span>
                            @Html.DropDownListFor(
                                m => m.Role,
                                new List<SelectListItem>
                                {
                                    new SelectListItem { Text = "Select Role", Value = "", Selected = true, Disabled = true },
                                    new SelectListItem { Text = "User", Value = "User" },
                                    new SelectListItem { Text = "Restaurant", Value = "Restaurant" },
                                    new SelectListItem { Text = "Admin", Value = "Admin" }
                                },
                                new
                                {
                                    @class = "form-select custom-input"
                                })
                        </div>
                    </div>

                    <!-- REMEMBER -->
                    <div class="form-check mb-4">
                        @Html.CheckBoxFor(
                            m => m.RememberMe,
                            new
                            {
                                @class = "form-check-input",
                                id = "rememberMe"
                            })
                        @Html.LabelFor(
                            m => m.RememberMe,
                            "Remember Me",
                            new { @class = "form-check-label", @for = "rememberMe" })
                    </div>

                    <!-- BUTTON -->
                    <div class="d-grid mb-4">
                        <button type="submit"
                                class="btn btn-primary login-btn">
                            Log In
                        </button>
                    </div>

                    <!-- SIGNUP -->
                    <div class="text-center">
                        Don't have an account?
                        @Html.ActionLink("SIGN UP HERE", "Register", "Account", null, new { @class = "signup-link" })
                    </div>
                }
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
    $(document).ready(function () {

        // ── Inline error helper ───────────────────────────────────────────────
        function showError(msg) {
            if (!$("#loginError").length) {
                $("#loginForm").prepend(
                    '<div id="loginError" class="alert alert-danger alert-dismissible fade show" role="alert">' +
                    '<i class="bi bi-exclamation-triangle-fill me-2"></i>' +
                    '<span id="loginErrorMsg"></span>' +
                    '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>' +
                    '</div>'
                );
            }
            $("#loginErrorMsg").text(msg);
            $("#loginError").show();
        }

        function clearError() {
            $("#loginError").hide();
        }

        // ── Client-side validation ────────────────────────────────────────────
        // (No email field on this form — only Username, Password, Role.)
        function validate() {
            var email = $("#Email").val().trim();
            var password = $("#Password").val().trim();
            var role     = $("#Role").val();

            if (!email) {
                showError("email is required.");
                $("#Email").focus();
                return false;
            }
            if (!password) {
                showError("Password is required.");
                $("#Password").focus();
                return false;
            }
            if (!role) {
                showError("Please select a role.");
                $("#Role").focus();
                return false;
            }
            return true;
        }

        // ── Clear error on input change ───────────────────────────────────────
        $("#Email, #Password, #Role").on("input change", function () {
            clearError();
            $(this).removeClass("is-invalid");
        });

        // ── Form submit ───────────────────────────────────────────────────────
        $("#loginForm").on("submit", function (e) {
            e.preventDefault();
            clearError();

            if (!validate()) return;

            var $btn = $(this).find("button[type='submit']");
            $btn.prop("disabled", true)
                .html('<span class="spinner-border spinner-border-sm me-2"></span>Logging in...');

            $.ajax({
                url: $(this).attr("action"),
                type: "POST",
                data: $(this).serialize(),
                success: function (res) {
                    if (res.success) {
                        window.location.href = res.redirectUrl;
                    } else {
                        showError(res.message || "Login failed. Please try again.");
                        resetBtn($btn);
                    }
                },
                error: function (xhr) {
                    var msg = "Something went wrong. Please try again.";
                    try {
                        var json = JSON.parse(xhr.responseText);
                        if (json && json.message) msg = json.message;
                    } catch (_) {}
                    showError(msg);
                    resetBtn($btn);
                }
            });
        });

        function resetBtn($btn) {
            $btn.prop("disabled", false).html("Log In");
        }

        // ── Toggle password visibility ────────────────────────────────────────
        $("#togglePassword").on("click", function () {
            var $pwd  = $("#Password");
            var $icon = $("#eyeIcon");
            if ($pwd.attr("type") === "password") {
                $pwd.attr("type", "text");
                $icon.removeClass("bi-eye-fill").addClass("bi-eye-slash-fill");
            } else {
                $pwd.attr("type", "password");
                $icon.removeClass("bi-eye-slash-fill").addClass("bi-eye-fill");
            }
        });
    });
    </script>
}
