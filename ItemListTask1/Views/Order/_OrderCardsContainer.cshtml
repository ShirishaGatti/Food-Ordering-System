@model ItemListModel.ViewModel.OrderViewModel
@{
    <!-- Pagination Logic -->
    int pageGroupSize = 5;
    int group = (Model.pageNumber - 1) / pageGroupSize;
    int startPage = group * pageGroupSize + 1;
    int endPage = Math.Min(startPage + pageGroupSize - 1, Model.ItemTotalPages);
    int startRecord = (Model.pageNumber - 1) * Model.pageSize + 1;
    int endRecord = Math.Min(Model.pageNumber * Model.pageSize, Model.ItemTotalCount);

}
<div class="d-flex justify-content-between align-items-center mt-3">
  
        <ul class="pagination mb-0 justify-content-start">

            @if (Model.pageNumber > 1)
            {
                <li class="page-item">
                    <a class="page-link"
                       href="#"
                       onclick="filterOrders(@(Model.pageNumber - 1)); return false;">
                        &laquo;
                    </a>
                </li>
            }
            else
            {
                <li class="page-item disabled">

                    <span class="page-link">
                        &laquo;
                    </span>

                </li>
            }

            @for (int i = startPage; i <= endPage; i++)
            {
                if (i == Model.pageNumber)
                {
                    <li class="page-item active">
                        <span class="page-link">
                            @i
                        </span>
                    </li>
                }
                else
                {
                    <li class="page-item">
                        <a class="page-link"
                           href="#"
                           onclick="filterOrders(@i); return false;">
                            @i
                        </a>
                    </li>
                }
            }
            @if (Model.pageNumber < Model.ItemTotalPages)
            {
                <li class="page-item">
                    <a class="page-link"
                       href="#"
                       onclick="filterOrders(@(Model.pageNumber + 1)); return false;">
                        &raquo;
                    </a>
                </li>
            }
            else
            {
                <li class="page-item disabled">
                    <span class="page-link">
                        &raquo;
                    </span>
                </li>
            }
        </ul>
        <div class="col-md-6 text-end">
            <p class="text-muted mb-0">
                Showing <strong>@startRecord</strong> to
                <strong>@endRecord</strong>
                of
                <strong>@Model.ItemTotalCount</strong> orders
            </p>
        </div>
    </div>



<!-- Bootstrap Pagination -->

<input type="hidden"
       id="totalPages"
       value="@Model.ItemTotalPages" />

@if (!Model.Orders.Any())
{
    <div class="alert alert-info shadow-sm">
        <h5 class="mb-2">
            No items found!
        </h5>
        <p class="mb-0">
            Please try different filters
            or reset your search.
        </p>
    </div>
}
else
{
    foreach (var order in Model.Orders)
    {
    //    <div class="col-12 col-sm-6 col-lg-4 col-xl-3 mb-3">
            <div class="col-12 col-sm-6 col-lg-4 col-xl-3 mb-3 mt-3">
                <div class="card shadow h-100">

                    <div class="card-header bg-primary text-white">
                        <strong>Order #@order.OrderId</strong>
                    </div>

                    <div class="card-body">
                        <p><strong>Date:</strong> @(order.OrderDate?.ToString("dd-MMM-yyyy"))</p>
                        <p><strong>User:</strong> @order.UserId</p>
                        <hr />
                        <table class="table table-sm table-borderless mb-0">
                            <thead>
                                <tr>
                                    <th>Item</th>
                                    <th class="text-center">Qty</th>
                                    <th class="text-end">Price</th>
                                    <th class="text-end">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in order.Items)
                                {
                                    <tr>
                                        <td>@item.ItemName</td>
                                        <td class="text-center">@item.Quantity</td>
                                        <td class="text-end">@item.Price</td>
                                        <td class="text-end">@item.SubTotal</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="card-footer">
                        <div class="d-flex justify-content-end align-items-center mb-2">
                            <strong>Total : ₹@order.TotalAmount</strong>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="button"
                                    class="btn btn-warning btn-sm edit-order-btn flex-fill"
                                    data-id="@order.OrderId">
                                ✏️ Edit
                            </button>
                            @*K     <p>Status: @order.IsActive</p>*@
                            @if (order.IsActive == true)
                    {
                                <button type="button"
                                        class="btn btn-danger btn-sm delete-order-btn flex-fill"
                                        data-id="@order.OrderId">
                                    🗑 Delete
                                </button>
                            }
                        </div>
                    </div>

                </div>
            </div>
    }
}

  
