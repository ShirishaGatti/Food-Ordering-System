@model ItemListModel.ViewModel.OrderViewModel

<div class="container mt-4">

    <div class="hero-section">
        <div class="hero-overlay">
            <div class="container text-center text-white">
                <h1 class="hero-title">📋 Orders Placed So Far</h1>
                <h6 class="hero-subtitle">Track user orders</h6>
            </div>
        </div>
    </div>

    <div class="service-item p-4" style="margin-bottom:30px;">

        <div class="row g-3 justify-content-center">
            <div class="col-md-2">
                <label class="fw-medium mb-2">
                Page Size
                </label>

                @Html.DropDownListFor(
                        m => m.pageSize,
                        new SelectList(new List<int>
                        {
                            1,2,3,5,10,20
                        }),
                        new
                        {
                            @class = "form-control",
                            id = "pageSize"
                        })

            </div>
              
            <div class="col-md-2">
                <label class="fw-medium mb-2">Date From</label>
                <input type="date" id="DateFrom" class="form-control"
                       value="@(Model.DateFrom?.ToString("yyyy-MM-dd") ?? "")" />
            </div>

            <div class="col-md-2">
                <label class="fw-medium mb-2">Date To</label>
                <input type="date" id="DateTo" class="form-control"
                       value="@(Model.DateTo?.ToString("yyyy-MM-dd") ?? "")" />
            </div>

            <div class="col-md-2">
                <label class="fw-medium mb-2">Price Filter</label>
                <select id="PriceRange" class="form-control">
                    <option value="">-- Select --</option>
                    <option value=">=" @(Model.PriceRange == ">=" ? "selected" : "")>Greater Than or Equal</option>
                    <option value="<=" @(Model.PriceRange == "<=" ? "selected" : "")>Less Than or Equal</option>
                    <option value=">" @(Model.PriceRange == ">" ? "selected" : "")>Greater Than</option>
                    <option value="<" @(Model.PriceRange == "<" ? "selected" : "")>Less Than</option>
                    <option value="=" @(Model.PriceRange == "=" ? "selected" : "")>Equal</option>
                </select>
            </div>

            <div class="col-md-2">
                <label class="fw-medium mb-2">Amount</label>
                <input type="number" id="Price" class="form-control"
                       placeholder="Enter amount" min="0"
                       value="@(Model.Price?.ToString() ?? "")" />
            </div>

            <div class="col-md-2">
                <label class="fw-medium mb-2">Status</label>
                <select id="statusFilter" class="form-control">
                    <option value="1" @(Model.Status == 1 ? "selected" : "")>Active</option>
                    <option value="0" @(Model.Status == 0 ? "selected" : "")>Inactive</option>
                    <option value="10" @(Model.Status == 10 ? "selected" : "")>Both</option>
                </select>
            </div>

            <div class="col-auto ms-auto justify-content-end align-items-end">
                <button type="button" id="applyOrderFilters"
                        class="btn btn-primary btn-sm">
                    🔍 Apply
                </button>
                <button type="button" id="resetOrderFilters"
                        class="btn btn-outline-secondary btn-sm">
                    ↺ Reset
                </button>
                <button type="button" id="addOrderBtn"
                        class="btn btn-outline-warning btn-sm">
                    ➕ Add
                </button>
            </div>

        </div>
    </div>


    <div id="loadingOverlay" style="display:none;" class="text-center mt-3">
        <div class="spinner-border text-warning" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-2 fw-semibold text-muted">Loading orders...</p>
    </div>


    <div class="row mt-4" id="orderCardsContainer">
        @Html.Partial("~/Views/Order/_OrderCardsContainer.cshtml", Model)    </div>

    <div class="toast-container position-fixed top-0 end-0 p-3">
        <div id="liveToast" class="toast" role="alert">
            <div class="toast-header">
                <strong class="me-auto">Success</strong>
                <button type="button" class="btn-close" data-bs-dismiss="toast"></button>
            </div>
            <div class="toast-body" id="toastBody"></div>
        </div>
    </div>
    <div class="modal fade" id="deleteOrderModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Delete Order</h5>
                </div>
                <div class="modal-body">
                    Are you sure you want to delete this order?
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>
                    <button type="button" class="btn btn-danger"
                            id="confirmDeleteOrderBtn">
                        Delete
                    </button>
                </div>
            </div>
        </div>
    </div>

</div>

<div id="orderModalContainer"></div>

@section scripts {
    <script>
        window.OrderConfig = {
            saveOrderUrl: '@Url.Action("SaveOrder", "Order")'
        };
    </script>
    <script src="~/Content/js/Order.js"></script>
}
    