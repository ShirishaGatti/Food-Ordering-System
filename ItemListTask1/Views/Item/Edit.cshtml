@model ItemListModel.ViewModel.ItemViewModel

@{
    ViewData["Title"] = "Edit Item";
}

<h2>Edit Item</h2>

@using (Html.BeginForm("ItemsUpdate", "Item", FormMethod.Post))
{
    @Html.HiddenFor(m => m.ItemId)

    <div class="mb-3">
        <label class="form-label">Item Name</label>
        @Html.TextBoxFor(m => m.ItemName, new { @class = "form-control", placeholder = "Enter item name" })
    </div>

    <div class="mb-3">
        <label class="form-label">Description</label>
        @Html.TextAreaFor(m => m.description, new { @class = "form-control", placeholder = "Enter description" })
    </div>

    <div class="mb-3">
        <label class="form-label">Price</label>
        @Html.TextBoxFor(m => m.price, new { @class = "form-control", type = "number", step = "0.01", placeholder = "Enter price" })
    </div>

    <div class="mb-3">
        <label class="form-label">Category</label>
        @Html.DropDownListFor(
            m => m.SelectedCategoryId,
            new SelectList(Model.FoodCategory, "FoodCategoryId", "FoodCategoryName", Model.SelectedCategoryId),
            "-- Select Category --",
            new { @class = "form-control" }
        )
    </div>

    <div class="mb-3">
        <label class="form-label">Restaurant</label>
        <input type="text" class="form-control" value="@Model.RestaurantName" readonly />
        @Html.HiddenFor(m => m.RestaurantId)
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a href="@Url.Action("ItemList", "Item")" class="btn btn-secondary ms-2">Cancel</a>
}
